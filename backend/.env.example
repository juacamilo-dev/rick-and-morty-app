# Server
PORT=4000
NODE_ENV=development

# MySQL (coinciden con docker-compose.yml)
DB_HOST=localhost
DB_PORT=3307
DB_NAME=rick_and_morty
DB_USER=rickmorty_user
DB_PASSWORD=rickmorty_pass
DB_ROOT_PASSWORD=root

# Redis (coincide con docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_TTL=3600

# Rick and Morty API
RICK_AND_MORTY_API=https://rickandmortyapi.com/api
